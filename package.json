{
  "name": "jimongroup-static",
  "private": true,
  "version": "1.0.0",
  "description": "Static localized site (en/ru/kk/ky/uz) served through TanStack Start routes for clean URLs.",
  "scripts": {
    "build": "python3 tools/build_static.py --public && vite build",
    "dev": "python3 tools/build_static.py --public && vite dev --host 0.0.0.0",
    "start": "python3 tools/build_static.py --public && vite dev --host 0.0.0.0",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.8",
    "@tanstack/react-start": "^1.168.13",
    "@tanstack/router-plugin": "^1.168.11",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^7.2.4",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
